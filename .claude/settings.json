{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git tag *)",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/skills/release/scripts/version_sync_check.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/publishing_reminder.py\""
          }
        ]
      }
    ]
  }
}
